{
	"multipart": [
		{ "apply": { "model": "automechs:block/data_cable_core" } },
		{ "when": { "north": "true" }, "apply": { "model": "automechs:block/data_cable_arm" } },
		{ "when": { "east": "true" },  "apply": { "model": "automechs:block/data_cable_arm", "y": 90 } },
		{ "when": { "south": "true" }, "apply": { "model": "automechs:block/data_cable_arm", "y": 180 } },
		{ "when": { "west": "true" },  "apply": { "model": "automechs:block/data_cable_arm", "y": 270 } },
		{ "when": { "up": "true" },    "apply": { "model": "automechs:block/data_cable_arm", "x": 270 } },
		{ "when": { "down": "true" },  "apply": { "model": "automechs:block/data_cable_arm", "x": 90 } }
	]
}
